<div class="sg-wrapper">

  <div class="sg-grid">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <div class="sg-cell" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | default: product.title }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="sg-cell__img"
          >
        {%- else -%}
          <div class="sg-cell__placeholder"></div>
        {%- endif -%}

        {%- if product != blank -%}
          <button
            type="button"
            class="sg-hotspot"
            style="left: {{ block.settings.hotspot_x }}%; top: {{ block.settings.hotspot_y }}%;"
            data-product-handle="{{ product.handle }}"
            aria-label="View product: {{ product.title | escape }}"
          >
            <span class="sg-hotspot__icon">+</span>
          </button>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

</div>

{%- comment -%}  SHARED PRODUCT MODAL  {%- endcomment -%}
<div class="sg-modal" id="sg-modal-{{ section.id }}" aria-hidden="true">
  <div class="sg-modal__backdrop" data-sg-close></div>
  <div class="sg-modal__box" role="dialog" aria-modal="true">
    <button type="button" class="sg-modal__close" data-sg-close aria-label="Close">&times;</button>

    <div class="sg-modal__loading">Loading...</div>

<div class="sg-modal__content" hidden>

  <div class="sg-modal__top">
    <div class="sg-modal__media">
      <img class="sg-modal__img" src="" alt="">
    </div>

    <div class="sg-modal__product-details">
      <h3 class="sg-modal__title"></h3>
      <p class="sg-modal__price"></p>
      <div class="sg-modal__desc"></div>
    </div>
  </div>

  <div class="sg-modal__options">
    <div class="sg-modal__option sg-modal__option--color" hidden>
      <p class="sg-modal__option-label">Color</p>
      <div class="sg-swatches"></div>
    </div>

    <div class="sg-modal__option sg-modal__option--size" hidden>
      <p class="sg-modal__option-label">Size</p>

      <div class="sg-size-wrapper">
        <select class="sg-size-select">
          <option value="">Choose your size</option>
        </select>

        <span class="sg-size-arrow">
          <svg
            width="14"
            height="8"
            viewBox="0 0 14 8"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M1 1L7 7L13 1"
              stroke="currentColor"
              stroke-width="1.5"
            />
          </svg>
        </span>
      </div>
    </div>
  </div>

  <button type="button" class="sg-add-to-cart">
    <span class="sg-add-to-cart__label">Add to Cart</span>
    <span class="sg-arrow">&#8594;</span>
  </button>

  <p class="sg-modal__error" hidden></p>
</div>
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .sg-wrapper {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.section_padding }}px 20px;
  }

  #shopify-section-{{ section.id }} .sg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  #shopify-section-{{ section.id }} .sg-cell {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background-color: #f2f2f2;
  }

  #shopify-section-{{ section.id }} .sg-cell__img,
  #shopify-section-{{ section.id }} .sg-cell__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .sg-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    color: #000;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .sg-hotspot:hover {
    background-color: #FFD500;
    transform: translate(-50%, -50%) scale(1.08);
  }

  /* ---------- MODAL ---------- */
  #shopify-section-{{ section.id }} .sg-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: none;
  }

  #shopify-section-{{ section.id }} .sg-modal.is-open {
    display: block;
  }

  #shopify-section-{{ section.id }} .sg-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

 #shopify-section-{{ section.id }} .sg-modal__box {
  position: relative;
  z-index: 1;
  background: #fff;
  max-width: 410px;
  width: calc(100% - 30px);
  margin: 4vh auto;
  max-height: 92vh;
  overflow-y: auto;
  border-radius: 0;
  padding: 48px 20px 22px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
}

#shopify-section-{{ section.id }} .sg-modal__close {
  position: absolute;
  top: 16px;
  right: 18px;
  width: 28px;
  height: 28px;
  padding: 0;
  background: transparent;
  border: none;
  color: #000;
  font-size: 25px;
  line-height: 1;
  cursor: pointer;
  z-index: 3;
}

#shopify-section-{{ section.id }} .sg-modal__top {
  display: grid;
  grid-template-columns: 43% 1fr;
  gap: 12px;
  align-items: start;
  width: 100%;
  margin-bottom: 12px;
}

#shopify-section-{{ section.id }} .sg-modal__media {
  width: 100%;
  height: 190px;
  margin: 0;
  overflow: hidden;
  background: #f3f3f3;
}

#shopify-section-{{ section.id }} .sg-modal__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

#shopify-section-{{ section.id }} .sg-modal__product-details {
  min-width: 0;
  padding-top: 2px;
}

#shopify-section-{{ section.id }} .sg-modal__title {
  margin: 0 0 10px;
  color: #111;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.2;
}

#shopify-section-{{ section.id }} .sg-modal__price {
  margin: 0 0 13px;
  color: #111;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.2;
}

#shopify-section-{{ section.id }} .sg-modal__desc {
  display: -webkit-box;
  overflow: hidden;
  color: #444;
  font-size: 13px;
  line-height: 1.15;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
}

#shopify-section-{{ section.id }} .sg-modal__options {
  clear: both;
  width: 100%;
}

#shopify-section-{{ section.id }} .sg-modal__option {
  width: 100%;
  margin: 0 0 16px;
}

#shopify-section-{{ section.id }} .sg-modal__option-label {
  margin: 0 0 5px;
  color: #333;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.2;
  letter-spacing: 0;
  text-transform: none;
}

/* Color buttons */
#shopify-section-{{ section.id }} .sg-swatches {
  display: flex;
  width: 100%;
  gap: 0;
}

#shopify-section-{{ section.id }} .sg-swatch {
  position: relative;
  flex: 1 1 0;
  min-height: 41px;
  margin: 0;
  padding: 9px 12px;
  background: #fff;
  border: 1px solid #b8b8b8;
  border-radius: 0;
  color: #111;
  font-size: 14px;
  font-weight: 400;
  text-align: left;
  cursor: pointer;
}

#shopify-section-{{ section.id }} .sg-swatch + .sg-swatch {
  margin-left: -1px;
}

#shopify-section-{{ section.id }} .sg-swatch.is-active {
  z-index: 2;
  border: 3px solid #000;
  padding: 7px 10px;
  font-weight: 400;
}

/* Size dropdown */
#shopify-section-{{ section.id }} .sg-size-wrapper {
  position: relative;
  display: flex;
  width: 100%;
}

#shopify-section-{{ section.id }} .sg-size-select {
  width: 100%;
  height: 43px;
  padding: 0 52px 0 13px;
  appearance: none;
  -webkit-appearance: none;
  background: #fff;
  border: 1px solid #b8b8b8;
  border-radius: 0;
  color: #111;
  font-size: 14px;
  cursor: pointer;
}

#shopify-section-{{ section.id }} .sg-size-arrow {
  position: absolute;
  top: 0;
  right: 0;
  display: flex;
  width: 50px;
  height: 100%;
  align-items: center;
  justify-content: center;
  border-left: 1px solid #b8b8b8;
  pointer-events: none;
}

/* Add to cart */
#shopify-section-{{ section.id }} .sg-add-to-cart {
  position: relative;
  width: 100%;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
  padding: 12px 55px;
  background: #000;
  border: 1px solid #000;
  border-radius: 0;
  color: #fff;
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: uppercase;
  cursor: pointer;
}

#shopify-section-{{ section.id }} .sg-arrow {
  position: absolute;
  right: 22px;
  font-size: 27px;
  font-weight: 300;
  line-height: 1;
}

#shopify-section-{{ section.id }} .sg-add-to-cart:hover {
  background: #000;
  color: #fff;
}

#shopify-section-{{ section.id }} .sg-add-to-cart:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

@media screen and (max-width: 480px) {
  #shopify-section-{{ section.id }} .sg-modal__box {
    padding: 46px 18px 20px;
  }

  #shopify-section-{{ section.id }} .sg-modal__top {
    grid-template-columns: 44% 1fr;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .sg-modal__media {
    height: 170px;
  }

  #shopify-section-{{ section.id }} .sg-modal__title,
  #shopify-section-{{ section.id }} .sg-modal__price {
    font-size: 15px;
  }

  #shopify-section-{{ section.id }} .sg-modal__desc {
    font-size: 12px;
  }
}
  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sg-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .sg-modal__media {
      width: 90px;
      height: 110px;
    }
  }
</style>

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var root = document.getElementById('shopify-section-' + sectionId);
    if (!root) return;

    var modal = document.getElementById('sg-modal-' + sectionId);
    var loadingEl = modal.querySelector('.sg-modal__loading');
    var contentEl = modal.querySelector('.sg-modal__content');
    var imgEl = modal.querySelector('.sg-modal__img');
    var titleEl = modal.querySelector('.sg-modal__title');
    var priceEl = modal.querySelector('.sg-modal__price');
    var descEl = modal.querySelector('.sg-modal__desc');
    var colorWrap = modal.querySelector('.sg-modal__option--color');
    var swatchesEl = modal.querySelector('.sg-swatches');
    var sizeWrap = modal.querySelector('.sg-modal__option--size');
    var sizeSelect = modal.querySelector('.sg-size-select');
    var addBtn = modal.querySelector('.sg-add-to-cart');
    var addBtnLabel = modal.querySelector('.sg-add-to-cart__label');
    var errorEl = modal.querySelector('.sg-modal__error');

    var currentProduct = null;
    var selectedOptions = {};

    function formatMoney(cents, currency) {
      var amount = (cents / 100).toFixed(2);
      return currency ? (amount + ' ' + currency) : amount;
    }

    function openModal() {
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    modal.addEventListener('click', function (e) {
      if (e.target.hasAttribute('data-sg-close')) closeModal();
    });

    function findVariant() {
      if (!currentProduct) return null;
      return currentProduct.variants.find(function (v) {
        return currentProduct.options.every(function (optName, idx) {
          var key = 'option' + (idx + 1);
          return !selectedOptions[optName] || v[key] === selectedOptions[optName];
        });
      });
    }

function formatMoney(cents) {
  if (window.Shopify && typeof Shopify.formatMoney === 'function') {
    return Shopify.formatMoney(
      cents,
      {{ shop.money_format | json }}
    );
  }

  return new Intl.NumberFormat(
    {{ request.locale.iso_code | default: 'en' | json }},
    {
      style: 'currency',
      currency: {{ cart.currency.iso_code | default: shop.currency | json }}
    }
  ).format(cents / 100);
}

function getOptionName(option, index) {
  if (typeof option === 'string') return option;

  if (option && option.name) {
    return option.name;
  }

  return 'Option ' + (index + 1);
}

function getOptionValues(product, optionIndex) {
  var key = 'option' + (optionIndex + 1);
  var values = [];

  product.variants.forEach(function (variant) {
    var value = variant[key];

    if (
      value !== null &&
      value !== undefined &&
      value !== '' &&
      values.indexOf(value) === -1
    ) {
      values.push(value);
    }
  });

  return values;
}

function allRequiredOptionsSelected() {
  if (!currentProduct) return false;

  return currentProduct.options.every(function (option, index) {
    var optionName = getOptionName(option, index);
    return Boolean(selectedOptions[optionName]);
  });
}

function findVariant() {
  if (!currentProduct || !allRequiredOptionsSelected()) {
    return null;
  }

  return currentProduct.variants.find(function (variant) {
    return currentProduct.options.every(function (option, index) {
      var optionName = getOptionName(option, index);
      var key = 'option' + (index + 1);

      return variant[key] === selectedOptions[optionName];
    });
  }) || null;
}

function updateVariantImage(variant) {
  if (!variant) return;

  var imageUrl = '';

  if (variant.featured_image) {
    imageUrl =
      variant.featured_image.src ||
      variant.featured_image.url ||
      '';
  }

  if (!imageUrl && currentProduct.featured_image) {
    imageUrl =
      typeof currentProduct.featured_image === 'string'
        ? currentProduct.featured_image
        : currentProduct.featured_image.src;
  }

  if (!imageUrl && currentProduct.images && currentProduct.images.length) {
    imageUrl =
      typeof currentProduct.images[0] === 'string'
        ? currentProduct.images[0]
        : currentProduct.images[0].src;
  }

  if (imageUrl) {
    imgEl.src = imageUrl;
  }
}

function updatePriceAndButton() {
  var variant = findVariant();

  delete addBtn.dataset.variantId;

  if (!allRequiredOptionsSelected()) {
    addBtn.disabled = true;
    addBtnLabel.textContent = 'Select Options';
    return;
  }

  if (!variant) {
    addBtn.disabled = true;
    addBtnLabel.textContent = 'Unavailable';
    return;
  }

  priceEl.textContent = formatMoney(variant.price);
  updateVariantImage(variant);

  addBtn.dataset.variantId = variant.id;
  addBtn.disabled = !variant.available;
  addBtnLabel.textContent = variant.available
    ? 'Add to Cart'
    : 'Sold Out';
}

function renderProduct(product) {
  currentProduct = product;
  selectedOptions = {};

  errorEl.hidden = true;
  errorEl.textContent = '';

  var featuredImage = product.featured_image;

  if (featuredImage && typeof featuredImage === 'object') {
    featuredImage = featuredImage.src;
  }

  if (!featuredImage && product.images && product.images.length) {
    featuredImage =
      typeof product.images[0] === 'string'
        ? product.images[0]
        : product.images[0].src;
  }

  imgEl.src = featuredImage || '';
  imgEl.alt = product.title || '';

  titleEl.textContent = product.title || '';
  priceEl.textContent = product.price
    ? formatMoney(product.price)
    : '';

  var temporaryElement = document.createElement('div');
  temporaryElement.innerHTML = product.description || '';

  descEl.textContent = temporaryElement.textContent
    .replace(/\s+/g, ' ')
    .trim();

  swatchesEl.innerHTML = '';
  sizeSelect.innerHTML =
    '<option value="">Choose your size</option>';

  colorWrap.hidden = true;
  sizeWrap.hidden = true;

  var sizeOptionName = '';

  product.options.forEach(function (option, index) {
    var optionName = getOptionName(option, index);
    var values = getOptionValues(product, index);

    var isColor = /color|colour|shade|finish/i.test(optionName);
    var isSize = /size|sizes/i.test(optionName);

    if (isColor) {
      colorWrap.hidden = false;

      values.forEach(function (value, valueIndex) {
        var button = document.createElement('button');

        button.type = 'button';
        button.className = 'sg-swatch';
        button.textContent = value;
        button.dataset.value = value;

        if (valueIndex === 0) {
          button.classList.add('is-active');
          selectedOptions[optionName] = value;
        }

        button.addEventListener('click', function () {
          swatchesEl
            .querySelectorAll('.sg-swatch')
            .forEach(function (swatch) {
              swatch.classList.remove('is-active');
            });

          button.classList.add('is-active');
          selectedOptions[optionName] = value;

          updatePriceAndButton();
        });

        swatchesEl.appendChild(button);
      });

      return;
    }

    if (isSize || !sizeOptionName) {
      sizeOptionName = optionName;
      sizeWrap.hidden = false;

      values.forEach(function (value) {
        var selectOption = document.createElement('option');

        selectOption.value = value;
        selectOption.textContent = value;

        sizeSelect.appendChild(selectOption);
      });
    }
  });

  sizeSelect.onchange = function () {
    if (!sizeOptionName) return;

    if (sizeSelect.value) {
      selectedOptions[sizeOptionName] = sizeSelect.value;
    } else {
      delete selectedOptions[sizeOptionName];
    }

    updatePriceAndButton();
  };

  updatePriceAndButton();
}

    addBtn.addEventListener('click', function () {
      var variantId = addBtn.dataset.variantId;
      if (!variantId) return;
      errorEl.hidden = true;
      addBtn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
        .then(function (res) {
          if (!res.ok) return res.json().then(function (data) { throw new Error(data.description || 'Could not add to cart'); });
          return res.json();
        })
        .then(function () {
          addBtnLabel.textContent = 'Added!';
          document.dispatchEvent(new CustomEvent('cart:updated'));
          setTimeout(function () { addBtnLabel.textContent = 'Add to Cart'; addBtn.disabled = false; }, 1500);
        })
        .catch(function (err) {
          errorEl.textContent = err.message;
          errorEl.hidden = false;
          addBtn.disabled = false;
        });
    });

    root.querySelectorAll('.sg-hotspot').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var handle = btn.dataset.productHandle;
        if (!handle) return;

        openModal();
        loadingEl.hidden = false;
        contentEl.hidden = true;

        fetch('/products/' + handle + '.js')
          .then(function (res) { return res.json(); })
          .then(function (product) {
            renderProduct(product);
            loadingEl.hidden = true;
            contentEl.hidden = false;
          })
          .catch(function () {
            loadingEl.textContent = 'Could not load product.';
          });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Shoppable Gallery",
  "settings": [
    { "type": "range", "id": "container_width", "min": 800, "max": 1600, "step": 20, "unit": "px", "label": "Max container width", "default": 1200 },
    { "type": "range", "id": "section_padding", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Section padding (top/bottom)", "default": 60 },
    { "type": "range", "id": "grid_gap", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Grid gap", "default": 16 },
    { "type": "collection", "id": "source_collection", "label": "Collection (optional reference)", "info": "Only used as a reference when picking products per block below; products from any collection can still be picked." }
  ],
  "blocks": [
    {
      "type": "image_product",
      "name": "Product Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "product", "id": "product", "label": "Linked product" },
        { "type": "range", "id": "hotspot_x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Hotspot X position", "default": 50 },
        { "type": "range", "id": "hotspot_y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Hotspot Y position", "default": 50 }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Shoppable Gallery",
      "blocks": [
        { "type": "image_product" },
        { "type": "image_product" },
        { "type": "image_product" },
        { "type": "image_product" },
        { "type": "image_product" },
        { "type": "image_product" }
      ]
    }
  ]
}
{% endschema %}
