
<div class="hb-wrapper" style="--bg-color: {{ section.settings.header_bg_color }};">

  {%- comment -%} ================= HEADER BAR ================= {%- endcomment -%}
  <div class="hb-header">
    <div class="hb-header__logo">
      {%- if section.settings.header_logo_type == 'image' and section.settings.header_logo_image != blank -%}
        <a href="{{ routes.root_url }}">
          <img
        src="{{ section.settings.header_logo_image | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            style="height: {{ section.settings.header_logo_height }}px; width: auto;"
            loading="eager"
            width="{{ section.settings.header_logo_image.width }}"
            height="{{ section.settings.header_logo_image.height }}"
          >
        </a>
      {%- else -%}
<a href="{{ routes.root_url }}" class="hb-header__logo-text" style="font-size: {{ section.settings.header_logo_height }}px;">
          {{ section.settings.header_logo_text | default: shop.name }}
        </a>
      {%- endif -%}
    </div>

       <div class="hb-header__cta">
      {%- if section.settings.header_button_label != blank -%}
        <a href="{{ section.settings.header_button_link | default: '#' }}" class="hb-btn hb-btn--header">
          {{ section.settings.header_button_label }}
          <span class="hb-arrow">&#8594;</span>
        </a>
      {%- endif -%}
    </div>

    <div class="hb-header__center hb-align-{{ section.settings.header_text_alignment }}">
      <p style="font-size: {{ section.settings.header_center_text_size }}px;">
        {{ section.settings.header_center_text }}
      </p>
    </div>
  </div>


 {%- comment -%} ================= HERO SECTION ================= {%- endcomment -%}


  <div class="hb-hero" style="background-image: url('{{ section.settings.hero_bg_image | image_url: width: 1800 }}');">
    <div class="hb-hero__overlay"></div>
    <div class="hb-hero__content">
      <h1 class="hb-hero__heading" style="--heading-size-desktop: {{ section.settings.hero_heading_size }}px; --heading-size-mobile: {{ section.settings.hero_heading_size_mobile }}px;">
        {{ section.settings.hero_heading }}
      </h1>
      <div class="hb-hero__desc">
        {{ section.settings.hero_description }}
      </div>
      {%- if section.settings.hero_button_label != blank -%}
        <a href="{{ section.settings.hero_button_link | default: '#' }}" class="hb-btn hb-btn--hero">
          {{ section.settings.hero_button_label }}
          <span class="hb-arrow">&#8594;</span>
        </a>
    {%- endif -%}
    </div>
  </div>


 {%- comment -%} ================= BOTTOM STRIP TEXT ================= {%- endcomment -%}
  {%- if section.settings.bottom_text != blank -%}
    <div class="hb-bottom-strip" style="background-color: {{ section.settings.bottom_bg_color }};">
      <p style="color: {{ section.settings.bottom_text_color }}; font-size: {{ section.settings.bottom_text_size }}px;">
        {{ section.settings.bottom_text }}
      </p>
    </div>
  {%- endif -%}

</div>



<style>
 #shopify-section-{{ section.id }} .hb-wrapper {
    width: 100%;
  }

/* ---------- HEADER BAR ---------- */
  #shopify-section-{{ section.id }} .hb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 14px 40px;
    background-color: var(--bg-color, #F5F5F5);
    border-bottom: 1px solid #e5e5e5;
    flex-wrap: wrap;
  }




</style>






{% schema %}
{
"name": "Hero + Header Banner",
"settings": [
{ "type": "header", "content": "Header Bar Settings" },
    { "type": "color", "id": "header_bg_color", "label": "Header background color", "default": "#F5F5F5" },
     { "type": "select", "id": "header_logo_type", "label": "Logo type", "options": [
        { "value": "text", "label": "Custom Text" },
        { "value": "image", "label": "Upload Logo Image" }
      ], "default": "text" },
 { "type": "text", "id": "header_logo_text", "label": "Logo text", "default": "TISSO VISON" },
    { "type": "image_picker", "id": "header_logo_image", "label": "Logo image" },
    { "type": "range", "id": "header_logo_height", "min": 16, "max": 100, "step": 2, "unit": "px", "label": "Logo height", "default": 22 },

     { "type": "text", "id": "header_center_text", "label": "Header center text", "default": "Find the ideal gift for your loved ones." },
    { "type": "range", "id": "header_center_text_size", "min": 10, "max": 32, "step": 1, "unit": "px", "label": "Header center text size", "default": 14 },
    { "type": "select", "id": "header_text_alignment", "label": "Header center text alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "center" },

{ "type": "text", "id": "header_button_label", "label": "Header button label", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "header_button_link", "label": "Header button link" },
    { "type": "color", "id": "header_button_bg", "label": "Header button background (default)", "default": "#F5D000" },
    { "type": "color", "id": "header_button_text", "label": "Header button text color (default)", "default": "#000000" },

    { "type": "header", "content": "Hero Section Settings" },
    { "type": "image_picker", "id": "hero_bg_image", "label": "Hero background image" },
    { "type": "richtext", "id": "hero_heading", "label": "Hero heading", "default": "<p>The Gift Guide</p>" },
    { "type": "range", "id": "hero_heading_size", "min": 24, "max": 100, "step": 2, "unit": "px", "label": "Hero heading size (desktop)", "default": 56 },
    { "type": "range", "id": "hero_heading_size_mobile", "min": 16, "max": 60, "step": 1, "unit": "px", "label": "Hero heading size (mobile)", "default": 32 },
    { "type": "richtext", "id": "hero_description", "label": "Hero description", "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>" },

    { "type": "text", "id": "hero_button_label", "label": "Hero button label", "default": "SHOP NOW" },
    { "type": "url", "id": "hero_button_link", "label": "Hero button link" },
    { "type": "color", "id": "hero_button_bg", "label": "Hero button background (default)", "default": "#000000" },
    { "type": "color", "id": "hero_button_text", "label": "Hero button text color (default)", "default": "#FFFFFF" },

     { "type": "header", "content": "Bottom Strip Text Settings" },
    { "type": "text", "id": "bottom_text", "label": "Bottom strip text", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" },
    { "type": "range", "id": "bottom_text_size", "min": 10, "max": 28, "step": 1, "unit": "px", "label": "Bottom text size", "default": 13 },
    { "type": "color", "id": "bottom_bg_color", "label": "Bottom strip background color", "default": "#F5F5F5" },
    { "type": "color", "id": "bottom_text_color", "label": "Bottom strip text color", "default": "#333333" }
  ],


   "presets": [
    { "name": "Hero + Header Banner" }
]
}
{% endschema %}




